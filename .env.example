# Copy this to `.env` and customize.
# `.env` is gitignored. `.env` is read automatically by `docker compose`.

# --------- Supabase auth keys (LOCAL DEV ONLY) ---------
# Well-known self-hosted defaults — tied to JWT_SECRET below.
# Replace with project-specific values for production.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxNzk5NTM1NjAwfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q
POSTGRES_PASSWORD=postgres

# --------- Google Gemini ---------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --------- Google OAuth (optional) ---------
# Authorized redirect URI to register: http://localhost:54321/auth/v1/callback
GOOGLE_OAUTH_ENABLED=false
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# Browser-visible client ID for Google Identity Services. Same value
# as SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID — public half is safe to expose.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --------- Dodo Payments (Phase 5) ---------
# Merchant of Record built for Indian founders selling globally — handles
# tax in 150+ countries, settles to your Indian bank as "export of services"
# with FIRA auto-generated. Sign up at https://dodopayments.com (no invite
# needed) and grab your API key from the dashboard.
DODO_PAYMENTS_API_KEY=
DODO_WEBHOOK_SECRET=
# test_mode while developing, live_mode after you go live.
DODO_ENVIRONMENT=test_mode

# --------- Postgres URLs (production) ---------
# DATABASE_URL — used by the running app at request time. In production
#   point this at Supabase's pgbouncer pooler (port 6543) so Cloud Run
#   instances share a small pool. The driver runs with prepare:false so
#   transaction-mode pooling is safe.
# DIRECT_URL — used by drizzle-kit for migrations and any session-level
#   work the pooler can't proxy. Use Supabase's direct connection URL
#   (port 5432).
# In local dev both can point at the same supabase-cli postgres.
# DATABASE_URL=postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# DIRECT_URL=postgresql://postgres.<project>:<password>@db.<project>.supabase.co:5432/postgres

# --------- Upstash Redis (rate limiting, scalable across instances) ---------
# Sign up at console.upstash.com — free tier covers millions of req/mo.
# Without these, rate limiting is silently disabled (fine for local dev,
# not fine for production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --------- Sentry (Phase 6) ---------
SENTRY_DSN=

# --------- Production email (deploy time) ---------
# Local dev uses Mailpit (started by supabase). For production deploy,
# sign up at resend.com (free 3k/month), verify your sending domain,
# and set these. They get wired into Supabase's GoTrue SMTP config.
# RESEND_API_KEY=re_...
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=${RESEND_API_KEY}
# SMTP_ADMIN_EMAIL=auth@yourdomain.com
# SMTP_SENDER_NAME=PageLens
