# Copy this to .env.local and fill in real values.
# .env.local is gitignored — never commit it.

# --------- Database (Supabase Postgres) ---------
# Local Supabase via `supabase start` exposes this automatically.
# Hosted: dashboard → Project Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --------- Supabase Auth + Storage ---------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public Supabase config (exposed to the browser — anon key only)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --------- Google Gemini ---------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --------- Stripe ---------
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --------- Upstash Redis (rate limiting) ---------
# https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --------- Sentry (errors) ---------
SENTRY_DSN=

# --------- App ---------
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
