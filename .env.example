SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# --------- Stripe (Phase 5) ---------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --------- Upstash Redis (Phase 6) ---------
UPSTASH_REDIS_REST_URL=
