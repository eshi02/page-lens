# Copy this to .env.local and fill in real values.
# .env.local is gitignored — never commit it.

# --------- Database (Supabase Postgres) ---------
# Local Supabase via `supabase start` exposes this connection string.
# Hosted: dashboard → Project Settings → Database → Connection String → URI
DATABASE_URL=

# --------- Supabase Auth + Storage ---------
# `supabase status` prints these for the local stack.
# For hosted: Project Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public Supabase config (exposed to the browser — anon key only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --------- Google Gemini ---------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --------- Google OAuth (for Supabase) ---------
# https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID (Web)
# Authorized redirect URI for local: http://127.0.0.1:54321/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# --------- Stripe (Phase 5) ---------
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --------- Upstash Redis — rate limiting (Phase 6) ---------
# https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --------- Sentry — errors (Phase 6) ---------
SENTRY_DSN=

# --------- App ---------
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
